# Server Configuration
PORT=3000
NODE_ENV=development

# OpenAI (Optional - for better AI responses)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Hugging Face (Alternative AI - Optional)
HUGGINGFACE_API_KEY=hf_your-token-here

# API Type: 'local' (demo), 'openai', or 'huggingface'
API_TYPE=local

# Twilio WhatsApp Configuration
# 1. Get Account SID & Auth Token from: https://www.twilio.com/console
# 2. Set WhatsApp number from: https://www.twilio.com/console/sms/whatsapp/learn
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Optional: For production HTTPS
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem